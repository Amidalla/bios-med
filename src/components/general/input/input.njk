{% macro render(
    type="text",
    size="md",
    id="",
    name="",
    placeholder="",
    value="",
    disabled=false,
    readonly=false,
    required=false,
    maxlength="",
    minlength="",
    autocomplete="",
    pattern="",
    min="",
    max="",
    step="",
    error=false,
    class="",
    icon="",
    data={},
    aria={}
) %}
{% set inputWrapperClasses = "input-wrapper" %}
{% if icon %}{% set inputWrapperClasses = inputWrapperClasses + " input-wrapper--has-icon" %}{% endif %}
{% if type == "date" %}{% set inputWrapperClasses = inputWrapperClasses + " input-wrapper--date" %}{% endif %}

{% set inputClasses = "input " + size %}
{% if error %}{% set inputClasses = inputClasses + " error" %}{% endif %}
{% if type == "date" %}{% set inputClasses = inputClasses + " input--date" %}{% endif %}
{% if class %}{% set inputClasses = inputClasses + " " + class %}{% endif %}

{% set renderType = "text" if type == "date" else type %}

{# Генерируем уникальный ID, если не передан или пустой #}
{% set finalId = id %}
{% if not finalId or finalId == "" %}
    {% set finalId = "input-" + (range(100000, 999999) | random | string) %}
{% endif %}

<div class="{{ inputWrapperClasses }}">
    {% if icon %}
        <span class="input-icon">
            {{ icon | safe }}
        </span>
    {% endif %}
    <input
        type="{{ renderType }}"
        class="{{ inputClasses }}"
        id="{{ finalId }}"
        {% if name %}name="{{ name }}"{% endif %}
        {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
        {% if value %}value="{{ value }}"{% endif %}
        {% if disabled %}disabled{% endif %}
        {% if readonly %}readonly{% endif %}
        {% if required %}required{% endif %}
        {% if maxlength %}maxlength="{{ maxlength }}"{% endif %}
        {% if minlength %}minlength="{{ minlength }}"{% endif %}
        {% if autocomplete %}autocomplete="{{ autocomplete }}"{% endif %}
        {% if pattern %}pattern="{{ pattern }}"{% endif %}
        {% if min and type != "date" %}min="{{ min }}"{% endif %}
        {% if max and type != "date" %}max="{{ max }}"{% endif %}
        {% if step %}step="{{ step }}"{% endif %}
        {% if type == "date" %}inputmode="numeric" autocomplete="off"{% endif %}
        {% if data %}
            {% for key, val in data %}
                data-{{ key | replace("_", "-") }}="{{ val }}"
            {% endfor %}
        {% endif %}
        {% if type == "date" %}data-mask="date"{% endif %}
        {% if aria %}
            {% for key, val in aria %}
                aria-{{ key | replace("_", "-") }}="{{ val }}"
            {% endfor %}
        {% endif %}
    >
</div>
{% endmacro %}