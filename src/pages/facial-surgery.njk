{% set meta = { title: "Операции на лице" } %}
{% set breadcrumbs = {
    items: [
        { title: "Главная", url: "/" },
        { title: "Услуги", url: "/services.html" },
        { title: "Операции на лице" }
    ]
} %}
{% set page = {
    heading: false,
    after_content: true,
    breadcrumbsSeparator: "line-gradient"
} %}
{% extends "layouts/default.njk" %}

{% block content %}
    {# Hero с кастомными параметрами для страницы ринопластики #}
    {% set hero = {
        title: "операции на лице в клинике BIOS",
        label: "Идеальные формы без компромиссов",
        description: "Естесственные и гармоничные пропорции тела благодаря передовым методикам пластической хирургии и опыту наших ведущих специалистов",
        buttonText: "Получить консультацию",
        buttonPopup: "popup-entry",
        linkText: "Результаты до/после",
        linkUrl: "#before-after-short",
        showRating: true,
        class: "hero-services-detail facial-surgery-hero",
        bg: "/assets/images/content/facial-surgery-bg.png",
        bgLaptop: "/assets/images/content/hero-services-detail-bg-laptop.png",
        bgTablet: "/assets/images/content/hero-services-detail-bg-tablet.png",
        bgMobile: "/assets/images/content/hero-services-detail-bg-mobile.png"
    } %}
    {% include "blocks/common/hero/hero-services-detail.njk" %}

    {% set servicesClass = "services-categories--modified" %}
    {% include "blocks/common/services-categories/services-categories-sub.njk" %}

    {# Переопределяем переменные для before-after-short #}
    {% set showSubtitle = true %}
    {% set subtitleText = "Ваше преображение - наша гордость" %}
    {% set buttonTextBeforeAfter = "Смотреть работы" %}
    {% set buttonLink = "/buttock-before-after" %}

    {% set tabsLabels = {
        face: "Имплантация",
        breast: "Подтяжка",
        body: "Липолифтинг"
    } %}

    {% set defaultTab = "face" %}

    {# Обновленные данные для новой карточки - одно изображение #}
    {% set images = {
        face: [
            "/assets/images/content/before-after-new.jpg",
            "/assets/images/content/before-after-new.jpg"
        ],
        breast: [
            "/assets/images/content/before-after-new.jpg"
        ],
        body: [
            "/assets/images/content/before-after-new.jpg"
        ]
    } %}

    {% set buttonText = buttonTextBeforeAfter %}
    {% include "blocks/common/before-after-short/before-after-short.njk" %}

    {% include "blocks/common/stories-short/stories-short-sub.njk" %}

    {# Переопределяем переменные для selection-operation #}
    {% set class = "selection-operation--enlargemen" %}
    {% set title = "Записаться на консультацию" %}
    {% set description = "Консультация бесплатно при проведении операции в BIOS Clinic." %}
    {% set buttonText = "Записаться" %}
    {% set buttonPopup = "popup-entry" %}

    {% include "blocks/common/selection-operation/selection-operation.njk" %}

    {% include "blocks/common/surgeons/surgeons.njk" %}
    {% include "blocks/common/price-list/price-list.njk" %}
    {% include "blocks/common/undergoing-surgery/undergoing-surgery-sub.njk" %}
    {% include "blocks/common/expert-advice/expert-advice.njk" %}
    {% include "blocks/common/advantages/advantages-sub.njk" %}
    {% include "blocks/common/questions/questions.njk" %}
    {% include "blocks/common/main-form/main-form.njk" %}
{% endblock %}

{% block after_content %}
{% endblock %}