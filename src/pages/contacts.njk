    breadcrumbsSeparator: "line-gradient"
} %}
{% extends "layouts/default.njk" %}

{% block content %}
    {% set hero = {
            title: "Контакты",
            class: "hero-services-detail hero-contacts"
        } %}

    {% include "blocks/common/hero/hero-contacts.njk" %}
    {% include "blocks/common/contact-address/contact-address.njk" %}
    {% include "blocks/common/contacts-routes/contacts-routes.njk" %}

    {% set class = "selection-operation--home" %}
