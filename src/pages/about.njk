{% set meta = { title: "О клинике" } %}
{% set breadcrumbs = {
    items: [
        { title: "Главная", url: "/" },
        { title: "О клинике", url: "/about.html" }
    ]
} %}
{% set page = {
    heading: false,
    after_content: true,
    breadcrumbsSeparator: "line-gradient"
} %}
{% extends "layouts/default.njk" %}

{% block content %}
    {# Hero с кастомными параметрами для страницы О клинике #}
    {% set hero = {
        title: "Клиника пластической хирургии Биос в&nbsp;Москве",
        class: "hero-services-detail about-hero"
    } %}
    {% include "blocks/common/hero/hero-services-detail.njk" %}

    {# Блоки, которые не нужны на странице О клинике - закомментированы #}
    {# {% include "blocks/common/enlargement-description/enlargement-description.njk" %} #}
    {# {% include "blocks/common/operations-types/magnification-types.njk" %} #}

    {# Переопределяем переменные для before-after-short #}
    {% set showSubtitle = true %}
    {% set subtitleText = "Ваше преображение - наша гордость" %}
    {% set buttonTextBeforeAfter = "Смотреть работы" %}
    {% set buttonLink = "/buttock-before-after" %}

    {% set tabsLabels = {
        face: "Имплантация",
        breast: "Подтяжка",
        body: "Липолифтинг"
    } %}

    {% set defaultTab = "face" %}

    {% set images = {
        face: [
            { before: "/assets/images/content/enlargemen-before-1.jpg", after: "/assets/images/content/enlargemen-after-1.jpg" },
            { before: "/assets/images/content/enlargemen-before-2.jpg", after: "/assets/images/content/enlargemen-after-2.jpg" }
        ],
        breast: [
            { before: "/assets/images/content/enlargemen-before-1.jpg", after: "/assets/images/content/enlargemen-after-1.jpg" }
        ],
        body: [
            { before: "/assets/images/content/enlargemen-before-2.jpg", after: "/assets/images/content/enlargemen-after-2.jpg" }
        ]
    } %}

    {% set buttonText = buttonTextBeforeAfter %}
    {% include "blocks/common/before-after-short/before-after-short.njk" %}

    {# Переопределяем переменные для selection-operation #}
    {% set class = "selection-operation--enlargemen" %}
    {% set title = "Записаться на консультацию" %}
    {% set description = "Консультация бесплатно при проведении операции в BIOS Clinic." %}
    {% set buttonText = "Записаться" %}
    {% set buttonPopup = "popup-entry" %}

    {% include "blocks/common/selection-operation/selection-operation.njk" %}

    {% include "blocks/common/surgeons-enlargemen/surgeons-enlargemen.njk" %}
    {% include "blocks/common/pricing/pricing-enlargemen.njk" %}
    {% include "blocks/common/undergoing-surgery/undergoing-surgery-sub.njk" %}
    {% include "blocks/common/expert-advice/expert-advice.njk" %}
    {% include "blocks/common/advantages/advantages-sub.njk" %}

    {% include "blocks/common/questions/questions.njk" %}
    {% include "blocks/common/main-form/main-form.njk" %}
{% endblock %}

{% block after_content %}
{% endblock %}