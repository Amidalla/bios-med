{# blocks/common/doctor/doctor.njk #}

{% from "components/general/operations-types-card/operations-types-card.njk" import operationsTypesCard %}

<section class="before-after-description section doctor">
    <div class="before-after-description__bg"></div>
    <div class="before-after-description__decor"></div>

    <div class="container">
        <div class="before-after-description__wrapper">
            <div class="border-container">
                <div class="before-after-description__stats">
                    <div class="before-after-description__stat">
                        <div class="before-after-description__stat-number">30+</div>
                        <div class="before-after-description__stat-label">лет опыта</div>
                    </div>
                    <div class="before-after-description__stat">
                        <div class="before-after-description__stat-number">12000+</div>
                        <div class="before-after-description__stat-label">операций</div>
                    </div>
                    <div class="before-after-description__stat">
                        <div class="before-after-description__stat-number">350</div>
                        <div class="before-after-description__stat-label">операций в год</div>
                    </div>
                    <div class="before-after-description__stat">
                         <div class="before-after-description__stat-number">98%</div>
                         <div class="before-after-description__stat-label">довольных клиентов</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="before-after-description__header">
            <h2 class="section-title"><span>Специализация доктора</span></h2>
            <p class="before-after-description__subtitle">Основные направления и виды операций, которые выполняет доктор</p>
        </div>

        <div class="before-after-description__grid">
            <div class="before-after-description__grid-wrapper">
                {% set operations = [
                    {
                        icon: "/assets/images/content/doctor-icon-1.png",
                        title: "Хейлопластика, пластика губ",
                        textItems: [
                            {
                                type: "list",
                                items: [
                                    "Булхорн (укорочение верхней губы)",
                                    "Corner lift (поднятие уголков губ)",
                                    "YV-пластика губ"
                                ]
                            }
                        ],
                        isImage: true
                    },
                    {
                        icon: "/assets/images/content/doctor-icon-2.png",
                        title: "Контурная пластика тела",
                        textItems: [
                            {
                                type: "list",
                                items: [
                                    "Абдоминопластика (пластика живота)",
                                    "Мини-абдоминопластика",
                                    "Глютеопластика (увеличение ягодиц имплантами)",
                                    "Подтяжка бедер и ягодиц",
                                    "Брахиопластика (пластика рук)",
                                    "Круропластика (коррекция формы голеней имплантами)",
                                    "Mommy Makeover (комплекс операций после родов)"
                                ]
                            }
                        ],
                        isImage: true
                    },
                    {
                        icon: "/assets/images/content/doctor-icon-3.png",
                        title: "Реконструктивная хирургия",
                        textItems: [
                            {
                                type: "list",
                                items: [
                                    "Реконструкция груди",
                                    "Коррекция после неудачных операций",
                                    "Коррекция рубцов и шрамов"
                                ]
                            }
                        ],
                        isImage: true
                    },
                    {
                        icon: "/assets/images/content/doctor-icon-4.png",
                        title: "Мужские операции",
                        textItems: [
                            {
                                type: "list",
                                items: [
                                    "Гинекомастия (уменьшение грудных желез у мужчин)"
                                ]
                            }
                        ],
                        isImage: true
                    },
                    {
                        icon: "/assets/images/content/doctor-icon-5.png",
                        title: "Пластика груди",
                        textItems: [
                            {
                                type: "list",
                                items: [
                                    "Увеличение груди (импланты)",
                                    "Подтяжка груди (мастопексия)",
                                    "Уменьшение груди (редукционная маммопластика)",
                                    "Коррекция асимметрии",
                                    "Замена имплантов"
                                ]
                            }
                        ],
                        isImage: true
                    }
                ] %}

                {% for operation in operations %}
                    {{ operationsTypesCard(
                        icon=operation.icon,
                        title=operation.title,
                        textItems=operation.textItems,
                        buttons=[],
                        showReadMore=false,
                        labels=[],
                        footerLinks=[],
                        isImage=operation.isImage
                    ) }}
                {% endfor %}
            </div>
        </div>
    </div>
</section>