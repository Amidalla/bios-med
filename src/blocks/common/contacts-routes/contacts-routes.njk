{# blocks/contacts/contacts-routes/contacts-routes.njk #}

{% from "components/general/direction-card/direction-card-sub.njk" import directionCard %}

<section class="contacts-routes section">
    <!-- Карта -->
    <div class="contacts-routes__map">
        <div class="contacts-routes__map-decor"></div>
        <iframe data-src="https://yandex.ru/map-widget/v1/?um=constructor%3Afdb0ab16e6bf784fedf4adf2885fb55ca72a3132d56c8317a17e7da689d2d517&amp;source=constructor" width="1280" height="720" frameborder="0" class="lazy" src="https://yandex.ru/map-widget/v1/?um=constructor%3Afdb0ab16e6bf784fedf4adf2885fb55ca72a3132d56c8317a17e7da689d2d517&amp;source=constructor" data-loaded="true">
        </iframe>
    </div>

    <div class="container">
        <!-- Заголовок и подзаголовок -->
        <div class="contacts-routes__header">
            {% set title = {
                text: "<span>Маршруты до клиники</span>",
                tag: "h2",
                class: "section-title"
            } %}
            {% include "components/general/title/title.njk" %}
            <p class="contacts-routes__subtitle">Выберите удобный способ добраться до клиники БИОС</p>
        </div>

        <!-- Сетка маршрутов -->
        <div class="contacts-routes__grid">
            {{ directionCard(
                icon="/assets/images/content/route-icon-1.png",
                title="От метро Аэропорт",
                label="Время в пути 10-15 мин",
                text="Выход из последнего вагона из центра. Из стеклянных дверей - направо. Маршрутное такси номер 412. Остановка ЦКБ Гражданской Авиации",
                isImage=true
            ) }}

            {{ directionCard(
                icon="/assets/images/content/route-icon-2.png",
                title="От МЦК Стрешнево",
                label="Время в пути 5-7 мин",
                text="Выход из МЦК Стрешнево номер 1 в сторону первого Красногорского проезда. Пройти вдоль Волоколамского шоссе до остановки Пехотная улица. Сесть на маршрутное такси номер 412. Проехать до остановки ЦКБ Гражданской Авиации",
                isImage=true
            ) }}

            {{ directionCard(
                icon="/assets/images/content/route-icon-3.png",
                title="На автомобиле",
                label="Время в пути 10-15 мин",
                text="Движение по Волоколамскому шоссе. Ориентируйтесь на район Покровское-Стрешнево. Поворот направо на Иваньковское шоссе. После поворота движение по шоссе 1 км через аллею парка и поворот далее на территорию больницы налево",
                isImage=true
            ) }}
        </div>

        <!-- Нижний блок -->
        <div class="contacts-routes__footer">
            <div class="border-container">
                <div class="contacts-routes__footer-item">
                    <h4 class="contacts-routes__footer-title">Как пройти до клиники</h4>
                    <p class="contacts-routes__footer-text">Поднимаетесь по пандусу. Вход через приемное отделение налево. Следуйте по стрелочкам до ресепшена клиники БИОС</p>
                </div>
            </div>
        </div>
    </div>
</section>