{% from "components/general/operations-types-card/operations-types-card.njk" import operationsTypesCard %}

<section class="rhinoplasty-types section">
    <div class="container">
        <div class="rhinoplasty-types__header">
            <h2 class="section-title"><span>Виды ринопластики</span></h2>
            <p class="rhinoplasty-types__subtitle">Эстетическая коррекция и омоложение для гармоничного преображения</p>
        </div>

        <div class="rhinoplasty-types__list">
            {% set cards = [
                {
                    serviceId: "entry",
                    icon: "/assets/images/content/rhino-type-1.png",
                    title: "Эстетическая ринопластика",
                    textItems: [
                        { type: "paragraph", content: "Коррекция формы и пропорций носа для создания гармоничного и естественного результата. Позволяет:" },
                        { type: "list", items: ["убрать горбинку", "скорректировать кончик носа", "сузить спинку и ноздри", "изменить форму и проекцию носа", "устранить асимметрию"] },
                        { type: "paragraph", content: "Выполняется открытым или закрытым способом в зависимости от задачи" }
                    ],
                    buttons: [{ text: "Записаться", type: "primary", show: true }],
                    showReadMore: true,
                    isImage: true
                },
                {
                    serviceId: "septoplasty",
                    icon: "/assets/images/content/rhino-type-2.png",
                    title: "Риносептопластика",
                    textItems: [
                        { type: "paragraph", content: "Комплексная операция, сочетающая эстетическую коррекцию и восстановление дыхания. Во время операции:" },
                        { type: "list", items: ["выравнивается носовая перегородка", "устраняются внутренние анатомические нарушения", "одновременно улучшается форма носа"] },
                        { type: "paragraph", content: "Наиболее частый вариант современной ринопластики" }
                    ],
                    buttons: [{ text: "Записаться", type: "primary", show: true }],
                    showReadMore: true,
                    isImage: true
                },
                {
                    serviceId: "reconstructive-rhinoplasty",
                    icon: "/assets/images/content/rhino-type-3.png",
                    title: "Реконструктивная (вторичная) ринопластика",
                    textItems: [
                        { type: "paragraph", content: "Сложная операция, направленная на восстановление формы и опорных структур носа после травм или предыдущих операций. Особенности:" },
                        { type: "list", items: ["восстановление каркаса носа", "работа с дефицитом тканей", "использование хрящевых трансплантатов"] },
                        { type: "paragraph", content: "Чаще всего используется собственный хрящ пациента (в том числе из ребра), что позволяет создать надёжную опору и добиться стабильного результата" }
                    ],
                    buttons: [{ text: "Реконструктивная ринопластика", type: "primary", show: true }],
                    showReadMore: true,
                    isImage: true
                }
            ] %}

            {% for card in cards %}
                {{ operationsTypesCard(
                    icon=card.icon,
                    title=card.title,
                    textItems=card.textItems,
                    buttons=card.buttons,
                    showReadMore=card.showReadMore,
                    isImage=card.isImage,
                    serviceId=card.serviceId
                ) }}
            {% endfor %}
        </div>
    </div>
</section>