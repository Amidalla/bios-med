{% from "components/general/operations-types-card/operations-types-card.njk" import operationsTypesCard %}

<section class="rhinoplasty-types section">
    <div class="container">
        <div class="rhinoplasty-types__header">
            <h2 class="section-title"><span>Виды ринопластики</span></h2>
            <p class="rhinoplasty-types__subtitle">Эстетическая коррекция и омоложение для гармоничного преображения</p>
        </div>

        <div class="rhinoplasty-types__list">
            {% set cards = [
                {
                    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="70" viewBox="0 0 40 70" fill="none"><path d="M35.2098 0V6.10619C29.3964 15.6726 15.845 36.3929 8.14721 42.7434C0.449406 49.0938 0.529592 54.3451 1.53191 56.177C3.87065 60.4513 8.38821 62.2832 11.756 62.2832C15.9657 62.2832 21.3783 65.9469 21.9796 69M11.756 58.6195C18.9727 56.177 24.6258 65.2142 32.8047 62.2832C40.9836 59.3522 37.816 51.6991 35.2098 48.2389" stroke="white" stroke-width="2.1"/></svg>',
                    title: "Эстетическая ринопластика",
                    textItems: [
                        { type: "paragraph", content: "Коррекция формы и пропорций носа для создания гармоничного и естественного результата. Позволяет:" },
                        { type: "list", items: ["убрать горбинку", "скорректировать кончик носа", "сузить спинку и ноздри", "изменить форму и проекцию носа", "устранить асимметрию"] },
                        { type: "paragraph", content: "Выполняется открытым или закрытым способом в зависимости от задачи" }
                    ],
                    buttons: [{ text: "Записаться", type: "primary", show: true, modal: "popup-entry" }],
                    showReadMore: true,
                    isImage: false
                },
                {
                    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="57" height="71" viewBox="0 0 57 71" fill="none"><path d="M17.5969 0.0480957C17.5969 7.57907 16.4885 25.0835 12.0551 34.8534C6.51332 47.0658 -0.87574 50.7295 1.58728 58.0569C3.55769 63.9189 9.38684 66.1985 12.0551 66.6056M37.3005 0.0480957C37.711 9.41093 39.394 29.48 42.8422 34.8534C47.1525 41.5702 57.6204 49.5083 54.5416 58.0569C52.0786 64.8959 45.7158 66.6056 42.8422 66.6056M8.48867 59.2782C9.96812 59.0746 13.394 59.1561 15.262 61.11C17.5969 63.5525 21.4195 69.0481 26.9613 69.0481C31.3947 69.0481 37.4291 63.7561 39.8922 61.11C40.7132 59.8888 43.2172 57.8127 46.6655 59.2782" stroke="white" stroke-width="2.2"/></svg>',
                    title: "Риносептопластика",
                    textItems: [
                        { type: "paragraph", content: "Комплексная операция, сочетающая эстетическую коррекцию и восстановление дыхания. Во время операции:" },
                        { type: "list", items: ["выравнивается носовая перегородка", "устраняются внутренние анатомические нарушения", "одновременно улучшается форма носа"] },
                        { type: "paragraph", content: "Наиболее частый вариант современной ринопластики" }
                    ],
                    buttons: [{ text: "Записаться", type: "primary", show: true, modal: "popup-entry" }],
                    showReadMore: true,
                    isImage: false
                },
                {
                    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="33" height="70" viewBox="0 0 33 70" fill="none"><path d="M4.58833 0.554688C4.31233 0.968687 3.89833 6.21269 5.27833 10.3527C6.65833 14.4927 9.83244 17.6667 15.0764 23.8767C20.3204 30.0867 20.7344 37.1247 23.2184 39.3327C25.7024 41.5407 32.3264 43.7487 31.6364 49.6827C30.9464 55.6167 29.8424 58.6527 23.2184 60.7227C17.9192 62.3787 17.7904 67.3007 18.3884 69.5547M7.34844 45.1287C3.89837 48.1187 -1.48377 55.2303 4.58833 59.7567C8.59046 62.2407 12.6618 59.5781 15.1876 57.1347M15.1876 57.1347C16.0108 56.3383 16.8528 55.7547 17.8365 55.7547C20.7345 55.2027 24.3225 55.8927 21.9765 57.1347C20.0997 58.1283 16.6685 57.5487 15.1876 57.1347Z" stroke="white" stroke-width="2"/><path d="M1 0.96875C1.23 6.67275 3.8428 20.5371 12.454 30.3627C23.218 42.6447 28.186 42.7827 29.29 48.5787C29.29 53.2707 28.186 55.7547 22.942 59.7567" stroke="white" stroke-width="2" stroke-dasharray="4 4"/></svg>',
                    title: "Реконструктивная (вторичная) ринопластика",
                    textItems: [
                        { type: "paragraph", content: "Сложная операция, направленная на восстановление формы и опорных структур носа после травм или предыдущих операций. Особенности:" },
                        { type: "list", items: ["восстановление каркаса носа", "работа с дефицитом тканей", "использование хрящевых трансплантатов"] },
                        { type: "paragraph", content: "Чаще всего используется собственный хрящ пациента (в том числе из ребра), что позволяет создать надёжную опору и добиться стабильного результата" }
                    ],
                    buttons: [{ text: "Реконструктивная ринопластика", type: "primary", show: true, modal: "popup-reconstructive-rhinoplasty" }],
                    showReadMore: true,
                    isImage: false
                }
            ] %}

            {% for card in cards %}
                {{ operationsTypesCard(
                    icon=card.icon,
                    title=card.title,
                    textItems=card.textItems,
                    buttons=card.buttons,
                    showReadMore=card.showReadMore,
                    isImage=card.isImage
                ) }}
            {% endfor %}
        </div>
    </div>
</section>