{# blocks/common/services-categories/services-categories-directions.njk #}

{% from "components/general/direction-card/direction-card.njk" import directionCard %}

<section class="services-categories section services-categories-directions">
    <div class="services-categories__bg"></div>
    <div class="services-categories__decor"></div>
    <div class="container">
        <!-- Заголовок и подзаголовок -->
        <div class="services-categories__header">
            {% set title = {
                text: "<span>Основные направления<br>пластической хирургии</span>",
                tag: "h2",
                class: "section-title"
            } %}
            {% include "components/general/title/title.njk" %}
            <p class="services-categories__subtitle">Современная пластическая хирургия охватывает три ключевых области коррекции</p>
        </div>

        <!-- Сетка направлений -->
        <div class="services-categories__grid">
            {{ directionCard(
                icon="/assets/images/content/direction-icon-1.png",
                title="Операции на лице",
                items=[
                    "Ринопластика - коррекция формы и функции носа;",
                    "Блефаропластика - коррекцция век, устранение нависания кожи;",
                    "Подтяжка лица (SMAS-лифтинг) - глубокое омоложение контуров лица и шеи"
                ],
                iconAlt="Операции на лице",
                isImage=true
            ) }}

            {{ directionCard(
                icon="/assets/images/content/direction-icon-2.png",
                title="Операции на теле",
                items=[
                    "Липосакция - удаление избыточных жировых отложений;",
                    "Абдоминопластика - коррекция формы живота;",
                    "Бодилифтинг - комплексная подтяжка и коррекия контуров тела"
                ],
                iconAlt="Операции на теле",
                isImage=true
            ) }}

            {{ directionCard(
                icon="/assets/images/content/direction-icon-3.png",
                title="Пластическая хирургия груди",
                items=[
                    "Маммопластика - увеличение или уменьшение объема груди;",
                    "Мастопексия - подтяжка и кореекция формы груди;",
                    "Реконструкция груди - восстановление после мастэктомии или травмы"
                ],
                iconAlt="Пластическая хирургия груди",
                isImage=true
            ) }}
        </div>
    </div>
</section>