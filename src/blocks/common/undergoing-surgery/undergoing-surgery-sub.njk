{% from "components/general/border-wrapper/border-wrapper.njk" import borderWrapper %}
{% from "components/general/information-card/information-card.njk" import informationCard %}

<section class="undergoing-surgery section undergoing-surgery-sub">

    {% call borderWrapper('Как проходит операция', 'h2', 'section-title', false, '/undergoing-surgery') %}
        <div class="container">
            <div class="undergoing-surgery__header">
                <p class="undergoing-surgery__subtitle">Процесс ринопластики проходит в несколько структурированных этапов для достижения наилучшего результата</p>
            </div>

            <div class="undergoing-surgery__grid">
                {{ informationCard(
                    icon="/assets/images/content/undergoing-surgery-sub1.png",
                    title="Консультация с хирургом",
                    text="Индивидуальный прием. Обсуждения пожеланий и составление плана операции. Ответы на все ваши вопросы"
                ) }}

                {{ informationCard(
                    icon="/assets/images/content/undergoing-surgery-sub2.png",
                    title="Подготовка
                           к операции",
                    text="Сдача необходимых анализов и обследований. Получение подробных рекомендаций по подготовке. Операция а современном операционном блоке под контролем опытной бригады анестезиологов и хирургов"
                ) }}

                {{ informationCard(
                    icon="/assets/images/content/undergoing-surgery-sub3.png",
                    title="Проведение операции",
                    text="Операция на современном операционном блоке под контролем опытной бригады анестезиологов и хирургов. Максимальный комфорт и безопасность"
                ) }}

                 {{ informationCard(
                     icon="/assets/images/content/undergoing-surgery-sub4.png",
                     title="Реабилитационный период и уход",
                     text="Назначается расписание перевязок и послеоперационных осмотров. Хирург дает подробные рекомендации, соблюдение которых приведут к быстрому восстановлению"
                  ) }}

                  {{ informationCard(
                     icon="/assets/images/content/undergoing-surgery-sub5.png",
                     title="Ваш идеальный результат",
                     text="После прохождения реабилитационного периода можно наблюдать окончательный результат. Наслаждайтесь своим новым, свежим и естественным образом, который сохранится на долгие годы"
                 ) }}
            </div>
        </div>
    {% endcall %}
</section>