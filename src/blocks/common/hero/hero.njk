<section class="hero section">
    <div class="container">
        <div class="hero__content">
            {% set title = {
                text: "Клиника
                       пластической
                       хирургии Биос",
                tag: "h1",
                class: "hero__title"
            } %}
            {% include "components/general/title/title.njk" %}

            {% set text %}
                Ваш путь к совершенству в Москве
            {% endset %}
            <div class="hero__text">
                {{ text }}
            </div>

            <div class="border-block">
                <button class="hero__btn">
                    <span>Записаться на консультацию</span>
                </button>
            </div>
        </div>

        <div class="hero__navigation">
            {% from "components/general/navigation-hero/navigation-hero.njk" import render as navigationHero %}

            {{ navigationHero(items=[
                { href: "#", title: "Пластическая хирургия" },
                { href: "#", title: "Увеличение груди" },
                { href: "#", title: "Пластика живота" },
                { href: "#", title: "Пластика век" },
                { href: "#", title: "Пластика ягодиц" },
                { href: "#", title: "Консультация врачей" }
