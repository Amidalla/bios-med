{# Hero компонент #}

{# Параметры по умолчанию #}
{% set heroTitle = hero.title | default("Клиника пластической хирургии Биос") %}
{% set heroSubtitle = hero.subtitle | default("Ваш путь к совершенству в Москве") %}
{% set heroShowButton = hero.showButton | default(true) %}
{% set heroButtonText = hero.buttonText | default("Записаться на консультацию") %}
{% set heroShowNavigation = hero.showNavigation | default(true) %}
{% set heroClass = hero.class | default("") %}

{# Параметры фона #}
{% set heroBg = hero.bg | default('/assets/images/content/hero-bg.png') %}
{% set heroBgLaptop = hero.bgLaptop | default('/assets/images/content/hero-bg-laptop.png') %}
{% set heroBgTablet = hero.bgTablet | default('/assets/images/content/hero-bg-tablet.png') %}
{% set heroBgMobile = hero.bgMobile | default('/assets/images/content/hero-bg-mobile.png') %}

<section class="hero section {{ heroClass }}">
    <div class="container">
        <div class="hero__content">
            {# Заголовок - простой h1 который точно работает #}
            <h1 class="hero__title">{{ heroTitle | safe }}</h1>

            {% if heroSubtitle %}
            <div class="hero__text">
                {{ heroSubtitle | safe }}
            </div>
            {% endif %}

            {% if heroShowButton %}
            <div class="border-block">
                <button class="hero__btn" data-src="popup-entry">
                    <span>{{ heroButtonText }}</span>
                </button>
            </div>
            {% endif %}
        </div>

        {% if heroShowNavigation %}
        <div class="hero__navigation">
            {% from "components/general/navigation-hero/navigation-hero.njk" import render as navigationHero %}

            {{ navigationHero(items=[
                { href: "#", title: "Пластическая хирургия" },
                { href: "#", title: "Увеличение груди" },
                { href: "#", title: "Пластика живота" },
                { href: "#", title: "Пластика век" },
                { href: "#", title: "Пластика ягодиц" },
                { href: "#", title: "Консультация врачей" }
            ]) }}
        </div>
        {% endif %}
    </div>

    {# Слайдер - 4 слайда (с img вместо svg) #}
    <div class="slider swiper">
        <div class="swiper-wrapper">
            {# Слайд 1 #}
            {% set params = {
                bgColor: "rgba(255, 255, 255, 0.55)",
                title: "актуальные спецпредложения",
                icon: './assets/images/content/hero-icon-1.png',
                iconAlt: 'Иконка спецпредложения 1',
                subtitle: "Подтяжка лица 1 зона",
                price: "149 000 ₽"
            } %}
            {% include "components/general/hero-slide-card/hero-slide-card.njk" %}

            {# Слайд 2 #}
            {% set params = {
                bgColor: "rgba(255, 255, 255, 0.55)",
                title: "актуальные спецпредложения",
                icon: './assets/images/content/hero-icon-2.png',
                iconAlt: 'Иконка спецпредложения 2',
                subtitle: "Абдоминопластика все включено + липосакция 1 зона в подарок",
                price: "250 000 ₽"
            } %}
            {% include "components/general/hero-slide-card/hero-slide-card.njk" %}

            {# Слайд 3 #}
            {% set params = {
                bgColor: "rgba(255, 255, 255, 0.55)",
                title: "актуальные спецпредложения",
                icon: './assets/images/content/hero-icon-1.png',
                iconAlt: 'Иконка спецпредложения 3',
                subtitle: "Подтяжка лица 1 зона",
                price: "149 000 ₽"
            } %}
            {% include "components/general/hero-slide-card/hero-slide-card.njk" %}

            {# Слайд 4 #}
            {% set params = {
                bgColor: "rgba(255, 255, 255, 0.55)",
                title: "актуальные спецпредложения",
                icon: './assets/images/content/hero-icon-2.png',
                iconAlt: 'Иконка спецпредложения 4',
                subtitle: "Абдоминопластика все включено + липосакция 1 зона в подарок",
                price: "250 000 ₽"
            } %}
            {% include "components/general/hero-slide-card/hero-slide-card.njk" %}
        </div>
    </div>

    {# Фон с picture #}
    <div class="hero__bg">
        <picture>
            <source
                media="(max-width: 759.98px)"
                srcset="{{ heroBgMobile }}">
            <source
                media="(max-width: 1309.98px)"
                srcset="{{ heroBgTablet }}">
            <source
                media="(max-width: 1669.98px)"
                srcset="{{ heroBgLaptop }}">
            <img class="lazy"
                src="{{ heroBg }}"
                alt="Фон"
            >
        </picture>
    </div>
</section>