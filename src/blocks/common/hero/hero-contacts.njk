{# Hero для деталок услуг #}

{# Параметры по умолчанию #}
{% set heroTitle = hero.title | default("Ринопластика: Искусство и наука преображения") %}
{% set heroLabel = hero.label | default(null) %}
{% set heroSubtitle = hero.subtitle | default(null) %}
{% set heroDescription = hero.description | default(null) %}
{% set heroButtonText = hero.buttonText | default(null) %}
{% set heroButtonPopup = hero.buttonPopup | default(null) %}
{% set heroLinkText = hero.linkText | default(null) %}
{% set heroLinkUrl = hero.linkUrl | default(null) %}
{% set heroShowRating = hero.showRating | default(false) %}
{% set heroClass = hero.class | default("") %}
{% set heroBeforeImage = hero.beforeImage | default(null) %}
{% set heroAfterImage = hero.afterImage | default(null) %}
{% set heroBeforeText = hero.beforeText | default("До") %}
{% set heroAfterText = hero.afterText | default("После") %}

<section class="hero section {{ heroClass }}">
    <div class="container">
        <div class="hero__content">
            {% if heroLabel %}
            <div class="section-label">{{ heroLabel }}</div>
            {% endif %}

            <h1 class="hero__title">{{ heroTitle | safe }}</h1>

            {% if heroSubtitle %}
            <div class="hero__subtitle">{{ heroSubtitle }}</div>
            {% endif %}

            {% if heroDescription %}
            <div class="hero__description">
                {{ heroDescription | safe }}
            </div>
            {% endif %}

            {% if heroButtonText and heroButtonPopup or heroLinkText and heroLinkUrl %}
            <div class="hero__actions">
                {% if heroButtonText and heroButtonPopup %}
                <div class="border-block">
                    <button class="hero__btn" data-src="{{ heroButtonPopup }}">
                        <span>{{ heroButtonText }}</span>
                    </button>
                </div>
                {% endif %}

                {% if heroLinkText and heroLinkUrl %}
                <div class="border-block">
                    <a href="{{ heroLinkUrl }}" class="hero__link">
                        <span>{{ heroLinkText }}</span>
                    </a>
                </div>
                {% endif %}
            </div>
            {% endif %}
        </div>

        {% if heroBeforeImage and heroAfterImage %}
        <div class="hero__card-ba">
            <div class="card-ba">
                <div class="card-ba__inner">
                    <div class="card-ba__col">
                        <div class="card-ba__image">
                            <img class="lazy" data-src="{{ heroBeforeImage }}" alt="{{ heroBeforeText }}">
                            <span class="card-ba__label">{{ heroBeforeText }}</span>
                        </div>
                    </div>
                    <div class="card-ba__col">
                        <div class="card-ba__image">
                            <img class="lazy" data-src="{{ heroAfterImage }}" alt="{{ heroAfterText }}">
                            <span class="card-ba__label">{{ heroAfterText }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>

    <div class="hero__cards">
       <div class="hero__cards-item contacts">
          <p class="hero__cards-title">Москва</p>
          <ul class="hero__cards-list">
             <li>Иваньковское шоссе, д.7</li>
             <li>
                <a href="tel:84957961145,">+7(495)796-11-45,</a><br>
                <a href="tel:89037961155,">+7(903)796-11-455</a>
             </li>
             <li><a href="mailto:bios-med@yandex.ru">bios-med@yandex.ru</a></li>
             <li>Пн-Сб: 8:30-19:00<br>
                 Вс: выходной/8:30-18:00</li>
          </ul>
