{# blocks/common/stories-short/stories-short-tabs.njk #}

{% from "components/general/video-review-card/video-review-card.njk" import videoReviewCard %}
{% from "components/general/tabs/tabs.njk" import render as tabsRender, panel %}

<section class="stories-short section stories-short-tabs">
    <div class="container">
        <div class="stories-short__header">
            {% set title = {
                text: "<span>истории пациентов</span>",
                tag: "h2",
                class: "section-title"
            } %}
            {% include "components/general/title/title.njk" %}
        </div>

        {%
            set tabsLabels = {
                all: "Все",
                face: "Лицо",
                breast: "Грудь",
                neck: "Шея"
            }
        %}

        {%
            set defaultTab = "all"
        %}

        {%
            set stories = {
                all: [
                    {
                        video: "https://rutube.ru/embed/video/a949b2d2150a6f95adc6e6436d5bc037/",
                        poster: "/assets/images/content/stories1.png",
                        name: "Анна Иванова",
                        text: "Самая лучшая операция. Все прошло легко, спокойно и безболезненно",
                        doctor: "Верхняя и нижняя блефаропластика, <b>Доктор Варданян Микаел Каренович</b>",
                        rating: 5
                    },
                    {
                        video: "https://rutube.ru/embed/video/a949b2d2150a6f95adc6e6436d5bc037/",
                        poster: "/assets/images/content/stories2.png",
                        name: "Екатерина Смирнова",
                        text: "“Подчеркнули мою индивидуальность. Также помогли вернуть дыхание”",
                        doctor: "Верхняя и нижняя блефаропластика, <b>Доктор Варданян Микаел Каренович</b>",
                        rating: 5
                    },
                    {
                        video: "https://rutube.ru/embed/video/a949b2d2150a6f95adc6e6436d5bc037/",
                        poster: "/assets/images/content/stories3.png",
                        name: "Мария Петрова",
                        text: "Теперь я снова уверена в себе",
                        doctor: "Верхняя и нижняя блефаропластика, <b>Доктор Варданян Микаел Каренович</b>",
                        rating: 5
                    },
                    {
                        video: "https://rutube.ru/embed/video/a949b2d2150a6f95adc6e6436d5bc037/",
                        poster: "/assets/images/content/stories1.png",
                        name: "Ольга Сидорова",
                        text: "Лучшая клиника в городе",
                        doctor: "Верхняя и нижняя блефаропластика, <b>Доктор Варданян Микаел Каренович</b>",
                        rating: 5
                    }
                ],
                face: [
                    {
                        video: "https://rutube.ru/embed/video/a949b2d2150a6f95adc6e6436d5bc037/",
                        poster: "/assets/images/content/stories1.png",
                        name: "Анна Иванова",
                        text: "Самая лучшая операция. Все прошло легко, спокойно и безболезненно",
                        doctor: "Верхняя и нижняя блефаропластика, <b>Доктор Варданян Микаел Каренович</b>",
                        rating: 5
                    }
                ],
                breast: [
                    {
                        video: "https://rutube.ru/embed/video/a949b2d2150a6f95adc6e6436d5bc037/",
                        poster: "/assets/images/content/stories2.png",
                        name: "Екатерина Смирнова",
                        text: "“Подчеркнули мою индивидуальность. Также помогли вернуть дыхание”",
                        doctor: "Верхняя и нижняя блефаропластика, <b>Доктор Варданян Микаел Каренович</b>",
                        rating: 5
                    }
                ],
                neck: [
                    {
                        video: "https://rutube.ru/embed/video/a949b2d2150a6f95adc6e6436d5bc037/",
                        poster: "/assets/images/content/stories3.png",
                        name: "Мария Петрова",
                        text: "Теперь я снова уверена в себе",
                        doctor: "Верхняя и нижняя блефаропластика, <b>Доктор Варданян Микаел Каренович</b>",
                        rating: 5
                    }
                ]
            }
        %}

        <!-- Табы -->
        {% call tabsRender(tabsLabels, defaultTab) %}

            {% for tabId, tabLabel in tabsLabels %}
                {% call panel(tabId, defaultTab == tabId) %}
                    {% set currentStories = stories[tabId] %}

                    <!-- Слайдер -->
                    <div class="stories-short__slider">
                        <div class="swiper stories-slider">
                            <div class="swiper-wrapper">
                                {% for story in currentStories %}
                                    <div class="swiper-slide">
                                        {{ videoReviewCard(
                                            story.video,
                                            story.poster,
                                            story.name,
                                            story.text,
                                            story.doctor,
                                            story.rating
                                        ) }}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                        <!-- Навигация -->
                        <div class="stories-slider__nav">
                            <div class="stories-slider__button-prev">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M14 6L8.34315 11.6569L14 17.3137" stroke="#BE9158" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                            <div class="stories-slider__button-next">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M10 6L15.6569 11.6569L10 17.3137" stroke="#BE9158" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                        </div>
                    </div>
                {% endcall %}
            {% endfor %}

        {% endcall %}
    </div>
</section>